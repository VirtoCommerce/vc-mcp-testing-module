{
  "name": "vc-mcp-testing-module",
  "version": "1.0.0",
  "description": "",
  "main": "config.js",
  "scripts": {
    "env:check": "node get_variables_env.js",
    "plugin:configure": "npx tsx bootstrap/install.ts",
    "plugin:check": "npx tsx bootstrap/install.ts --check",
    "plugin:install": "echo '\"plugin:install\" was renamed to \"plugin:configure\" — Claude Code handles plugin install via /plugin install. Run npm run plugin:configure for env setup.' && exit 1",
    "ci:regression": "npx tsx ci/run-regression.ts",
    "ci:smoke": "SUITE_SELECTION=smoke npx tsx ci/run-regression.ts",
    "ci:critical": "SUITE_SELECTION=critical npx tsx ci/run-regression.ts",
    "ci:backend": "SUITE_SELECTION=backend npx tsx ci/run-regression.ts",
    "ci:frontend": "SUITE_SELECTION=frontend npx tsx ci/run-regression.ts",
    "ci:full": "SUITE_SELECTION=full MAX_BUDGET_USD=80 npx tsx ci/run-regression.ts",
    "ci:notify": "npx tsx ci/notify-teams.ts",
    "ci:cycle": "npx tsx ci/run-full-cycle.ts",
    "ci:cycle:pr": "CHANGE_SOURCE=\"PR #${PR_NUMBER}\" npx tsx ci/run-full-cycle.ts",
    "ci:cycle:sync-only": "SKIP_LIFECYCLE=true SKIP_REGRESSION=true npx tsx ci/run-full-cycle.ts",
    "ci:cycle:no-sync": "SKIP_SYNC=true npx tsx ci/run-full-cycle.ts",
    "seed": "node scripts/seed-test-data.js",
    "seed:minimal": "node scripts/seed-test-data.js minimal",
    "seed:catalog": "node scripts/seed-test-data.js catalog",
    "seed:full": "node scripts/seed-test-data.js full",
    "seed:teardown": "node scripts/seed-test-data.js teardown",
    "seed:dry-run": "node scripts/seed-test-data.js catalog --dry-run --verbose",
    "schema:refresh": "node scripts/refresh-graphql-schema.mjs",
    "schema:check": "node scripts/refresh-graphql-schema.mjs --dry-run > /dev/null",
    "refresh-product-guids": "node scripts/refresh-product-guids.mjs",
    "graphql:validate": "npx tsx scripts/graphql-runner.ts --all-fixtures",
    "graphql:validate:refresh": "npx tsx scripts/graphql-runner.ts --all-fixtures --refresh-schema",
    "graphql:lint-labels": "npx tsx scripts/review-graphql-labels.ts",
    "graphql:cleanup-leaked": "npx tsx scripts/cleanup-leaked-orgs.ts",
    "graphql:fixtures:validate": "npx tsx scripts/validate-graphql-fixtures.ts",
    "graphql:fixtures:validate:refresh": "npx tsx scripts/validate-graphql-fixtures.ts --refresh",
    "graphql:fixtures:update": "npx tsx scripts/update-graphql-fixtures.ts",
    "graphql:fixtures:update:dry": "npx tsx scripts/update-graphql-fixtures.ts --dry-run",
    "graphql:fixtures:bump": "npx tsx scripts/update-graphql-fixtures.ts --bump",
    "graphql:fixtures:rename": "npx tsx scripts/update-graphql-fixtures.ts --apply-renames",
    "report:graphql": "npx tsx scripts/generate-graphql-html-report.ts",
    "report:graphql:open": "npx tsx scripts/generate-graphql-html-report.ts --open",
    "report:regression": "npx tsx scripts/generate-regression-html-report.ts",
    "report:regression:open": "npx tsx scripts/generate-regression-html-report.ts --open",
    "report:regression:portable": "npx tsx scripts/generate-regression-html-report.ts --embed-images",
    "suites:sync": "npx tsx scripts/sync-test-suites.ts",
    "suites:lint": "npx tsx scripts/sync-test-suites.ts --check",
    "scope:validate": "npx tsx scripts/validate-critical-ui-scope.ts",
    "verify:multi-env": "npx tsx scripts/verify-multi-env-filters.ts",
    "verify:multi-env:report": "npx tsx scripts/verify-multi-env-filters.ts --write-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VirtoCommerce/vc-mcp-testing-module.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/VirtoCommerce/vc-mcp-testing-module/issues"
  },
  "homepage": "https://github.com/VirtoCommerce/vc-mcp-testing-module#readme",
  "dependencies": {
    "@playwright/mcp": "^0.0.75",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.14.0",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.140",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.19.19",
    "csv-stringify": "^6.7.0",
    "playwright": "^1.60.0",
    "tsx": "^4.0.0"
  }
}
