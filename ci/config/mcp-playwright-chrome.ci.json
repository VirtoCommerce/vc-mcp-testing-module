{
  "browser": {
    "browserName": "chromium",
    "launchOptions": {
      "headless": true,
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage",
        "--disable-gpu"
      ]
    },
    "contextOptions": {
      "viewport": {
        "width": 1920,
        "height": 1080
      },
      "ignoreHTTPSErrors": true,
      "locale": "en-US",
      "timezoneId": "America/New_York",
      "recordHar": {
        "path": "./test-results/chrome/trace.har",
        "omitContent": true
      }
    }
  },
  "isolated": true,
  "outputDir": "./test-results/chrome",
  "screenshot": "only-on-failure"
}
