# ==============================================================================
# Per-environment template (Bucket #2: per-env URLs/identifiers, committed, NO secrets)
# ==============================================================================
#
# QUICK START
#   1. Copy this file to .env.<your-env-name>   (name is arbitrary: [a-z0-9_]+)
#        cp .env.example .env.acme_staging
#   2. Fill in the values below for that environment.
#   3. Put secrets (passwords/tokens) in .env.local — see the secrets block at the
#      bottom of this file. Use the _<ENV_NAME_UPPER> suffix so config.js promotes
#      them only for that env (e.g. USER_PASSWORD_ACME_STAGING -> USER_PASSWORD).
#   4. Activate it for a single run:
#        PowerShell:  $env:TEST_ENV='acme_staging'; npm run env:check
#        bash/CI:     TEST_ENV=acme_staging npm run env:check
#
# MAKE IT YOUR TEAM/PERSONAL DEFAULT (so you don't pass TEST_ENV every time)
#   Create a gitignored .env.test-env file containing one line:
#        TEST_ENV=acme_staging
#   Resolution precedence (highest first), see scripts/lib/resolve-test-env.js:
#        1. process.env.TEST_ENV   (explicit shell/CI override — always wins)
#        2. .env.test-env          (this default)
#        3. 'vcst'                 (repo fallback)
#
# HOW THE LAYERS COMBINE (later overrides earlier), see config.js:
#   .env.defaults  ->  .env.${TEST_ENV}  ->  .env.local  ->  legacy .env
#
# Prefer the interactive scaffolder if you'd rather be prompted:
#   npx tsx bootstrap/install.ts --env=acme_staging      (npm run plugin:configure)
# ==============================================================================

# --- Multi-env metadata (drives suite gating; see config.js) ------------------
# STOREFRONT_PROFILE: b2b | b2c | hybrid — gates which suites apply.
STOREFRONT_PROFILE=hybrid
# ENV_RISK: dev | test | staging | production — production blocks admin-write
# suites by default (safety-by-config, NOT by env name).
ENV_RISK=test
# MODULES_ENABLED: CSV of installed VC modules (empty = no filter).
MODULES_ENABLED=
# PAYMENT_PROCESSORS_ENABLED: CSV of processors you use
# (cybersource,skyflow,authorize-net,datatrance,stripe). Empty = no filter.
PAYMENT_PROCESSORS_ENABLED=
# JIRA_PROJECT_KEY: your JIRA project for bug filing.
JIRA_PROJECT_KEY=VCST

# --- Application URLs (REQUIRED) ---------------------------------------------
FRONT_URL=https://<your-storefront-host>
BACK_URL=https://<your-platform-host>
# Admin SPA / platform backend — usually same host as BACK_URL.
ADMIN_URL=https://<your-platform-host>
# Optional surfaces:
STORYBOOK_URL=
STORYBOOK_DEV_URL=

# --- Store configuration (REQUIRED: STORE_ID) --------------------------------
STORE_ID=B2B-store
STOREFRONT_DOMAIN=<your-storefront-host>
# Real GUID of USER_EMAIL on this env — used as a session userId hint (optional).
TEST_USER_ID=

# --- User identifiers (passwords go in .env.local, NOT here) -----------------
# Admin (Platform SPA) login name.
ADMIN=admin
# Alias of ADMIN — suites reference {{ADMIN_EMAIL}} as the OAuth username.
ADMIN_EMAIL=admin
# Main storefront user.
USER_EMAIL=
# Secondary storefront user (B2B / list-sharing / multi-user suites).
USER2_EMAIL=
# B2B / multi-org / EUR / impersonation users (optional — leave blank if unused).
MULTI_ORG_USER_EMAIL=
EUR_USER_EMAIL=
ORG_USER_EMAIL=
# Dedicated lockout-test account, isolated from the agent pool (optional).
LOCKOUT_TEST_EMAIL=

# --- Seed fixture SKUs (optional — set after seeding test data) ---------------
VALID_COUPON_CODE=
OOS_SKU=
LOW_STOCK_SKU=
PACK_SIZE_SKU=
TIER_PRICED_SKU=
CONFIGURABLE_SKU=

# --- Integration identifiers (tokens/passwords in .env.local) ----------------
JIRA_EMAIL=

# --- Azure Application Insights — online bug monitoring (optional) ------------
# Powers /qa-monitoring + `npm run ci:monitor`. Leave the App IDs blank to disable
# the flow (it no-ops with a clear message). Two separate resources: one for the
# platform/backend, one for the storefront.
#   - App ID = the App Insights resource's "Application ID" GUID
#              (Portal: resource > Configure > API Access > Application ID).
# AUTH is AAD-first: the query client uses your Azure identity (az login / VS Code
# Azure / a CI service principal / managed identity) — NO API key needed in a
# dev or Azure-connected CI environment. API keys are an OPTIONAL fallback for
# runners with no Azure identity (create one under API Access > "Read telemetry",
# put it in .env.local). Force key auth with MONITOR_AUTH=key.
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
APPINSIGHTS_APP_ID_BACKEND=
APPINSIGHTS_APP_ID_STOREFRONT=
# Resource display names — only used to build Azure Portal deep-links in reports
# (e.g. the App Insights resource name in the portal). Optional; links are omitted
# when unset. Per-env — do not hardcode an environment's resource name in code.
APPINSIGHTS_RESOURCE_BACKEND=
APPINSIGHTS_RESOURCE_STOREFRONT=

# ==============================================================================
# SECRETS — do NOT put these here. Add to .env.local (gitignored), suffixed with
# _<ENV_NAME_UPPER> so they activate only for this env. Example for "acme_staging":
#
#   ADMIN_PASSWORD_ACME_STAGING=...
#   USER_PASSWORD_ACME_STAGING=...
#   USER2_PASSWORD_ACME_STAGING=...
#   JIRA_API_TOKEN=...            # cross-env secrets need no suffix
#   APPINSIGHTS_API_KEY_BACKEND=...      # App Insights read-telemetry keys
#   APPINSIGHTS_API_KEY_STOREFRONT=...   # (per-env: add the _<ENV_UPPER> suffix)
#
# config.js promotes USER_PASSWORD_ACME_STAGING -> USER_PASSWORD when
# TEST_ENV=acme_staging. Payment sandbox cards are shared defaults already set
# in .env.defaults — only override per-env if your sandbox is non-standard.
# ==============================================================================
