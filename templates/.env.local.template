# ==============================================================================
# .env.local — customer secrets (GITIGNORED, never commit)
# ==============================================================================
#
# This template is what `npm run plugin:install` writes to .env.local for you.
# Edit by hand if you need to add more env profiles or change individual values.
#
# config.js (the layered env loader) reads, in order:
#   1. .env.defaults          — plugin-supplied constants (sandbox cards, etc.)
#   2. .env.${TEST_ENV}       — customer-required per-env values (URLs, IDs)
#   3. .env.local             — THIS FILE: secrets with per-env suffix promotion
#
# Per-env suffix promotion: when TEST_ENV=qa, the loader auto-promotes any var
# ending in `_QA` to its base name. So `USER_PASSWORD_QA=…` becomes
# `USER_PASSWORD` at runtime. This lets you keep ALL env credentials in ONE
# gitignored file without duplicating effort or risking commits of secrets.
#
# Rules:
#   - Env suffix must match [A-Z0-9_]+ (uppercase of your TEST_ENV).
#   - TEST_ENV must match [a-z0-9_]+ — kebab-case is rejected.
# ==============================================================================

# --- Storefront test user (per-env) ------------------------------------------
# Non-admin user. Used by checkout, cart, account, B2B-org tests.
USER_EMAIL_QA=qa-user@example.com
USER_PASSWORD_QA=replace-me
USER_EMAIL_STAGING=staging-user@example.com
USER_PASSWORD_STAGING=replace-me
USER_EMAIL_PROD=prod-readonly-user@example.com
USER_PASSWORD_PROD=replace-me

# --- Secondary storefront user (for B2B org tests, list sharing, etc.) -------
USER2_EMAIL_QA=qa-user2@example.com
USER2_PASSWORD_QA=replace-me
USER2_EMAIL_STAGING=
USER2_PASSWORD_STAGING=

# --- Admin SPA user (per-env) ------------------------------------------------
# Has back-office access. Some Backend suites require admin-write permissions —
# tag those suites with envRiskGate: "staging" if you don't want them on prod.
ADMIN_QA=qa-admin@example.com
ADMIN_PASSWORD_QA=replace-me
ADMIN_STAGING=staging-admin@example.com
ADMIN_PASSWORD_STAGING=replace-me
ADMIN_PROD=prod-readonly-admin@example.com
ADMIN_PASSWORD_PROD=replace-me

# --- Multi-org user (B2B suites only) ----------------------------------------
# A user that belongs to 2+ orgs — required by suite 006-b2c-organization for
# org-switch tests. Leave empty if you don't run B2B suites.
MULTI_ORG_USER_EMAIL_QA=
MULTI_ORG_USER_PASSWORD_QA=

# --- API + Integration secrets (cross-env, usually one set per customer) -----
# These don't typically vary per env (one API key per provider account).
FIGMA_API_KEY=
POSTMAN_API_KEY=
BUILDER_IO_EMAIL=
BUILDER_IO_PASSWORD=

# --- Atlassian / JIRA (for /qa-bug filing, /qa-status, /qa-test-plan) --------
# Typically configured at MCP level, not env vars. See docs/onboarding.md
# § Atlassian MCP setup.
# JIRA_PROJECT_KEY itself is per-env (lives in .env.${TEST_ENV}).

# --- BrowserStack (optional — only if you run cross-browser cloud tests) -----
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
