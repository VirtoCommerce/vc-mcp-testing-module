{
  "_meta": {
    "description": "Test data aliases for @td() references in suite CSVs. Syntax: @td(ALIAS.field) or @td(file, filter, column)",
    "version": "1.2.0",
    "updated": "2026-04-27"
  },
  "CFG_LAPTOP": {
    "file": "products/configurable-products",
    "filter": { "product_id": "CFG-013" },
    "fields": {
      "id": "product_id_guid",
      "name": "product_name",
      "slug": "product_slug",
      "url": "storefront_url",
      "price": "base_price"
    },
    "notes": "Two required Product sections (RAM, Storage). 9 price combos $999-$1399. For GraphQL configuration suite (050i)."
  },
  "CFG_RING": {
    "file": "products/configurable-products",
    "filter": { "product_id": "CFG-017" },
    "fields": {
      "id": "product_id_guid",
      "name": "product_name",
      "slug": "product_slug",
      "url": "storefront_url",
      "price": "base_price"
    },
    "notes": "Required Text section, maxLength=30. For Text-section validation tests."
  },
  "CFG_GIFTBOX": {
    "file": "products/configurable-products",
