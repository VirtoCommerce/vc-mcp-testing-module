  "CFG_CONDITIONAL_BIKE": {
    "file": "products/configurable-products",
    "filter": { "product_id": "CFG-022" },
    "fields": {
      "id": "product_id_guid",
      "name": "product_name",
      "slug": "product_slug",
      "url": "storefront_url",
