    },
    "notes": "Optional Text section, maxLength=100. For optional Text happy path."
  },
  "CFG_HOODIE": {
    "file": "products/configurable-products",
    "filter": { "product_id": "CFG-003" },
    "fields": {
      "id": "product_id_guid",
      "name": "product_name",
      "slug": "product_slug",
