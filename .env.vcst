# ==============================================================================
# vcst-qa environment — primary QA (default when TEST_ENV is unset)
# Activate: TEST_ENV=vcst npm run env:check  (or just `npm run env:check`)
# Committed; URLs/identifiers only — secrets live in .env.local
# ==============================================================================

# --- Application URLs --------------------------------------------------------
FRONT_URL=https://vcst-qa-storefront.govirto.com
BACK_URL=https://vcst-qa.govirto.com
STORYBOOK_URL=https://vcst-qa-storybook.govirto.com
STORYBOOK_DEV_URL=https://vcst-dev-storybook.govirto.com

# --- Store configuration -----------------------------------------------------
STORE_ID=B2B-store
STOREFRONT_DOMAIN=vcst-qa-storefront.govirto.com
# Real GUID of USER_EMAIL on this environment — session-hint userId arg
TEST_USER_ID=42765f34-51cf-4994-806b-e82e65fd5c14

# --- User identifiers (passwords in .env.local) ------------------------------
# Admin (Platform SPA)
ADMIN=admin
# Alias of ADMIN — many suite CSVs reference {{ADMIN_EMAIL}} as the OAuth
# username for /connect/token grant_type=password. Same value as ADMIN.
ADMIN_EMAIL=admin
# Admin SPA / platform backend URL — same host as BACK_URL.
# Many suites use {{ADMIN_URL}} as a [NAV] target; kept as a separate alias
# so admin-only navigation can be retargeted per-env without touching BACK_URL.
ADMIN_URL=https://vcst-qa.govirto.com

# Main storefront user (multi-org, orgId: d62aed2c)
