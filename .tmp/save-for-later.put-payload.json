              "body": {
                "mode": "graphql",
                "graphql": {
                  "query": "query Me { me { id userName email } }",
                  "variables": ""
                }
              }
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "var d = pm.response.json();",
                    "pm.test('No GraphQL errors', () => pm.expect(d.errors).to.be.undefined);",
                    "pm.test('me.id present', () => pm.expect(d.data.me.id).to.be.a('string').that.is.not.empty);",
                    "pm.environment.set('userId', d.data.me.id);"
                  ]
                }
              }
            ],
            "id": "0311ea44-cd65-4a69-86a7-715ba2e0b663"
          }
        ],
        "id": "fbe258a8-cfbb-47ae-b0ec-8d3cdf91c87a"
