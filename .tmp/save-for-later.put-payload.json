      {
        "name": "01-Setup",
        "item": [
          {
            "name": "Me Query — Capture USER_ID",
            "request": {
              "method": "POST",
              "url": "{{baseUrlGraphql}}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
