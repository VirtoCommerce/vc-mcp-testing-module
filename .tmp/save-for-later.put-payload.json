        "name": "00-Auth",
        "item": [
          {
            "name": "Storefront Token",
            "request": {
              "auth": {
                "type": "noauth"
              },
              "method": "POST",
              "url": "{{baseUrlRest}}/connect/token",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/x-www-form-urlencoded"
                }
              ],
              "body": {
                "mode": "urlencoded",
                "urlencoded": [
                  {
                    "key": "grant_type",
                    "value": "password"
                  },
                  {
                    "key": "username",
                    "value": "{{userEmail}}"
                  },
                  {
                    "key": "password",
                    "value": "{{userPassword}}"
                  },
                  {
                    "key": "scope",
                    "value": "offline_access"
                  },
                  {
                    "key": "storeId",
                    "value": "{{storeIdSf}}"
                  }
                ]
              }
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                    "var d = pm.response.json();",
                    "pm.test('Token returned', () => pm.expect(d.access_token).to.be.a('string').that.is.not.empty);",
                    "pm.environment.set('authToken', d.access_token);"
                  ]
                }
              }
            ],
            "id": "e6185e79-91b0-456b-ac08-0668fca479cb"
          }
