      {
        "name": "02-Pre-Cleanup",
        "item": [
          {
            "name": "Clear Default Cart",
            "request": {
              "method": "POST",
              "url": "{{baseUrlGraphql}}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "graphql",
                "graphql": {
                  "query": "mutation ClearDefaultCart { clearCart(command: { storeId: \"{{storeIdSf}}\" userId: \"{{userId}}\" cartName: \"default\" cultureName: \"{{cultureName}}\" currencyCode: \"{{currencyCode}}\" }) { id itemsCount } }",
                  "variables": ""
                }
              }
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "var d = pm.response.json();",
                    "pm.test('No GraphQL errors', () => pm.expect(d.errors).to.be.undefined);",
                    "pm.test('Default cart cleared', () => pm.expect(d.data.clearCart.itemsCount).to.eql(0));"
                  ]
                }
              }
            ],
            "id": "09f26e35-f9ff-4260-b961-7e036ce6bb49"
          },
          {
            "name": "Find Saved-For-Later Cart Id",
            "request": {
              "method": "POST",
              "url": "{{baseUrlGraphql}}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "graphql",
                "graphql": {
                  "query": "query FindSavedForLater { getSavedForLater(storeId: \"{{storeIdSf}}\" userId: \"{{userId}}\" currencyCode: \"{{currencyCode}}\" cultureName: \"{{cultureName}}\") { id name itemsCount } }",
                  "variables": ""
                }
              }
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "var d = pm.response.json();",
                    "pm.test('No GraphQL errors', () => pm.expect(d.errors).to.be.undefined);",
                    "var sfl = d.data.getSavedForLater;",
                    "pm.collectionVariables.set('savedCartIdToClear', sfl ? sfl.id : '');",
                    "console.log('Saved-for-later lookup:', sfl ? ('cart=' + sfl.name + ' id=' + sfl.id + ' itemsCount=' + sfl.itemsCount) : 'none');"
                  ]
                }
              }
            ],
            "id": "f7ffe3c0-5ecc-4318-be2c-a70c332173b1"
          },
          {
            "name": "Sweep Saved-For-Later Cart If Exists",
            "request": {
              "method": "POST",
              "url": "{{baseUrlGraphql}}",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "graphql",
                "graphql": {
                  "query": "mutation SweepSavedForLater { removeCart(command: { userId: \"{{userId}}\" cartId: \"{{savedCartIdToClear}}\" }) }",
                  "variables": ""
                }
              }
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "var savedCartIdToClear = pm.collectionVariables.get('savedCartIdToClear');",
                    "var d = pm.response.json();",
                    "if (!savedCartIdToClear) {",
                    "  pm.test('No saved-for-later cart existed — no-op cleanup passes', () => {",
                    "    pm.expect(d.errors, 'expected an error for empty cartId').to.be.an('array').that.is.not.empty;",
                    "  });",
                    "} else {",
                    "  pm.test('No GraphQL errors', () => pm.expect(d.errors).to.be.undefined);",
                    "  pm.test('removeCart returned true', () => pm.expect(d.data.removeCart).to.eql(true));",
                    "}"
                  ]
                }
              }
            ],
            "id": "1576789d-ea29-491e-9025-a03dac898dab"
          }
        ],
        "id": "5855acc0-50a2-4081-8555-71c507f0c475"
