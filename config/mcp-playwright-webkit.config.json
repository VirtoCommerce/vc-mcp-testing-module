{
  "browser": {
    "browserName": "webkit",
    "launchOptions": {
      "headless": false
    },
    "contextOptions": {
      "viewport": {
        "width": 1920,
        "height": 1080
      },
      "recordVideo": {
        "dir": "./test-results/webkit/videos",
        "video": "on-failure",
        "size": {
          "width": 1920,
          "height": 1080
        }
      },
      "recordHar": {
        "path": "./test-results/webkit/har",
        "omitContent": true
      }
    }
  },
  "isolated": true,
  "outputDir": "./test-results/webkit",
  "screenshot": "only-on-failure"
}