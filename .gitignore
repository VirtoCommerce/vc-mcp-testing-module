# Regression / lifecycle / coverage run evidence — ephemeral by policy.
# Root paths catch live customer / VC active runs.
# vc/shared/reports/ paths catch the archived Layer-2 mirror after the
# 2026-06-02 reports->vc/shared/reports/ move (workstream #6).
reports/regression/REG-*/**/*.png
reports/regression/REG-*/**/*.har
reports/regression/REG-*/**/*.jpg
reports/test-lifecycle/TLC-*/**/*.png
reports/test-lifecycle/TLC-*/**/*.har
reports/test-lifecycle/TLC-*/**/*.jpg
reports/coverage/COV-*/**/*.png
reports/coverage/COV-*/**/*.har
reports/coverage/COV-*/**/*.jpg
vc/shared/reports/regression/REG-*/**/*.png
vc/shared/reports/regression/REG-*/**/*.har
vc/shared/reports/regression/REG-*/**/*.jpg
vc/shared/reports/test-lifecycle/TLC-*/**/*.png
vc/shared/reports/test-lifecycle/TLC-*/**/*.har
vc/shared/reports/test-lifecycle/TLC-*/**/*.jpg
vc/shared/reports/coverage/COV-*/**/*.png
vc/shared/reports/coverage/COV-*/**/*.har
vc/shared/reports/coverage/COV-*/**/*.jpg

# Playwright MCP accessibility snapshots — dropped at repo root by browser MCPs
# during exploratory sessions. Transient working state, not deliverables.
# (No tracked YAML at repo root, so the bare-yml pattern is safe.)
/*.yml
/*.yaml

# Auto-fix pipeline — cloned product-repo source is transient working state
.fix-workspace/
# Auto-fix module discovery + dependency-graph cache (rebuilt from gh on TTL)
ci/config/.module-registry.cache.json
# Auto-fix run evidence (keep fix-report.md + summary.json, drop heavy artifacts)
reports/fixes/FIX-*/**/*.png
reports/fixes/FIX-*/**/*.har
reports/fixes/FIX-*/**/*.jpg

# Online monitoring (App Insights) — fingerprint dedup state is local working
# state, not a report. Keep MONITOR-* reports; drop heavy run artifacts.
reports/monitoring/.seen-fingerprints.json
reports/monitoring/MONITOR-*/**/*.png
reports/monitoring/MONITOR-*/**/*.har
reports/monitoring/MONITOR-*/**/*.jpg
